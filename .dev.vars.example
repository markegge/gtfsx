# Copy this to `.dev.vars` and fill in values. Wrangler loads `.dev.vars`
# during `wrangler dev` only; it's not uploaded on `wrangler deploy` and it
# overrides the `vars` block in wrangler.jsonc locally.
#
# .dev.vars is gitignored (matches `*.local`-style patterns? No — add
# explicitly to .gitignore if your repo doesn't already cover it).

# Point emailed links at the local Vite dev server, not production.
# Must be `localhost` (not 127.0.0.1) — Vite binds to localhost by default,
# and cookies on 127.0.0.1 don't share with cookies on localhost.
APP_ORIGIN=http://localhost:5173
FEEDS_ORIGIN=http://localhost:5173
AUTH_EMAIL_FROM=GTFS·X Dev <dev@example.com>

# Real Resend API key — reuse the one from bozeman-pod/.env if you have one,
# or create a test key at resend.com. Without a working key, signup/
# magic-link/password-reset will fail on the email-send step.
RESEND_API_KEY=re_your_dev_key_here

# For the catalog-search Worker. If you're not using /_import/search locally,
# any string works.
MOBILITY_DATABASE_REFRESH_TOKEN=unused-locally

# Welcome email (sent once on first account activation). Both optional locally:
#  - WELCOME_REPLY_TO: reply-to inbox on the welcome mail (prod: hello@gtfsx.com).
#    When unset, the welcome email falls back to AUTH_EMAIL_FROM.
#  - WELCOME_BCC: address BCC'd on every welcome mail (prod: mark@gtfsx.com).
#    When unset, no bcc is added.
#    Possibly deprecated: not read anywhere in worker/env.ts or the rest of
#    the Worker code as of 2026-07 — verify before relying on it.
WELCOME_REPLY_TO=hello@gtfsx.com
WELCOME_BCC=mark@gtfsx.com

# Transitland API key (transit.land). Not referenced by worker/ or scripts/
# in this repo as of 2026-07 — kept for tooling outside this repo that reads
# the same .dev.vars file.
TRANSITLAND_API_KEY=

# Neon API key, used for Postgres branch/PITR operations against other
# projects' Neon databases from scripts run out of this checkout (see
# proj-level PITR-recovery notes). Not referenced by worker/ itself.
NEON_API_KEY=

# Smartlead API key. Not referenced by worker/ or scripts/ in this repo as of
# 2026-07 — kept for outreach-automation tooling outside this repo.
SMARTLEAD_API_KEY=

# Stripe (billing). Test-mode secret key for local/staging dev; the live
# secret key and webhook signing secret are `wrangler secret put` in
# prod/staging, not normally needed for plain `wrangler dev` locally.
STRIPE_SECRET_KEY_TEST=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=
