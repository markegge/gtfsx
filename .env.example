VITE_MAPBOX_TOKEN=pk.YOUR_MAPBOX_PUBLIC_TOKEN_HERE
VITE_BACKEND_ENABLED=false

# Cloudflare Turnstile site key (public; baked into the bundle).
# Required to gate the signup form. Empty = widget skipped (dev only).
# The matching TURNSTILE_SECRET_KEY is set as a Worker secret via
# `wrangler secret put TURNSTILE_SECRET_KEY [--env staging]`.
VITE_TURNSTILE_SITE_KEY=

# Stripe (freemium / paid plans). pk_test_* for staging, pk_live_* for prod.
# Get from https://dashboard.stripe.com/test/apikeys after signing up.
# Pairs with STRIPE_SECRET_KEY (Worker secret) and STRIPE_WEBHOOK_SIGNING_SECRET.
VITE_STRIPE_PUBLISHABLE_KEY=
# Independent kill-switch for the billing UI. When false, paywall overlays
# render in an informational ("coming soon") state instead of triggering Stripe
# Checkout. Pairs with the BILLING_ENABLED Worker var.
VITE_BILLING_ENABLED=false

# US Census Bureau API key (free, register at
# https://api.census.gov/data/key_signup.html). Used by the Coverage and
# Title VI analysis features for the ACS5 endpoint, which began requiring a
# key for unauthenticated requests in 2026. The key is baked into the bundle
# (treated as a per-app rate-limit token by Census, not a strict secret).
VITE_CENSUS_API_KEY=
