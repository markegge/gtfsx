{
  "name": "gtfs-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build-docs-search-index.mjs && node scripts/build-sitemap.mjs && tsc -b && vite build",
    "build:prod": "node scripts/build-prod.mjs",
    "check:prod-bundle": "node scripts/check-prod-bundle.mjs",
    "deploy:prod": "npm run build:prod && wrangler deploy",
    "build:docs-index": "node scripts/build-docs-search-index.mjs",
    "build:sitemap": "node scripts/build-sitemap.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:frontend": "vitest run --config vitest.frontend.config.ts",
    "test:worker": "vitest run --fileParallelism=false",
    "test:editor": "tsx run-tests.ts",
    "test:e2e": "playwright test",
    "test:e2e:staging": "E2E_STAGING=1 playwright test --project=staging",
    "test:external": "tsx tests/external/check.ts",
    "test:validator-parity": "tsx tests/external/validator-parity.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mapbox/mapbox-gl-draw": "^1.5.1",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-popover": "^1.1.19",
    "@tanstack/react-table": "^8.21.3",
    "@turf/bearing": "^7.3.5",
    "@turf/boolean-point-in-polygon": "^7.3.4",
    "@turf/buffer": "^7.3.5",
    "@turf/distance": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "@turf/length": "^7.3.5",
    "@turf/nearest-point-on-line": "^7.3.5",
    "@turf/simplify": "^7.3.5",
    "@turf/transform-translate": "^7.3.5",
    "@turf/union": "^7.3.4",
    "date-fns": "^4.4.0",
    "dexie": "^4.4.4",
    "flatgeobuf": "^4.4.0",
    "gtfs-realtime-bindings": "^2.1.0",
    "hono": "^4.12.30",
    "immer": "^11.1.11",
    "jszip": "^3.10.1",
    "mapbox-gl": "^3.26.0",
    "papaparse": "^5.5.4",
    "pmtiles": "^4.4.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-map-gl": "^8.1.1",
    "react-router-dom": "^7.18.1",
    "stripe": "^22.3.2",
    "ulidx": "^2.4.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@cloudflare/workers-types": "^5.20260715.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^24.12.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "ajv": "^8.20.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "marked": "^18.0.6",
    "postcss": "^8.5.18",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
