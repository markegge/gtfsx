{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://www.gtfsbuilder.net",
          "https://gtfsbuilder.net",
          "http://localhost:5173",
          "http://localhost:4173"
        ],
        "methods": ["GET", "HEAD"],
        "headers": ["Range", "If-Match", "If-None-Match", "If-Modified-Since"]
      },
      "exposeHeaders": ["ETag", "Content-Length", "Content-Range", "Accept-Ranges"],
      "maxAgeSeconds": 3600
    }
  ]
}
